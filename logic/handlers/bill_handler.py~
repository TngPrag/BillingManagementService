# DELETE bill by ID (biller or admin), only if status pending
async def delete_bill_handler(request: Request, bill_id: str, user):
    if user.role not in ["biller", "admin"]:
        return JSONResponse({"detail": "Not authorized"}, status.HTTP_403_FORBIDDEN)

    try:
        bill_uuid = uuid.UUID(bill_id)
    except ValueError:
        return JSONResponse({"detail": "Invalid bill ID format"}, status.HTTP_422_UNPROCESSABLE_ENTITY)

    db = next(get_db())
    read_res = bill_model.get_bill_by_id(db, bill_uuid)

    if not read_res.success:
        return JSONResponse({"detail": read_res.error}, status.HTTP_404_NOT_FOUND)

    bill = read_res.data
    if bill.status != "pending":
        return JSONResponse({"detail": "Cannot delete non-pending bill"}, status.HTTP_400_BAD_REQUEST)

    result = bill_model.delete_bill(db, bill_uuid)
    if not result.success:
        return JSONResponse({"detail": result.error}, status.HTTP_400_BAD_REQUEST)

    return JSONResponse(status_code=status.HTTP_204_NO_CONTENT, content=None)


# READ all bills by status (roles: biller/admin/customer)
async def read_all_bills_by_status_handler(request: Request, state: str, user):
    if user.role not in ["admin", "biller", "customer"]:
        return JSONResponse({"detail": "Not authorized"}, status.HTTP_403_FORBIDDEN)

    db = next(get_db())
    result = bill_model.list_many_bills_by_status(db, state)

    if not result.success:
        return JSONResponse({"detail": result.error}, status.HTTP_500_INTERNAL_SERVER_ERROR)

    if user.role == "admin":
        bills = [b.__dict__ for b in result.data]
    elif user.role == "biller":
        bills = [b.__dict__ for b in result.data if b.biller_id == user.id]
    elif user.role == "customer":
        bills = [b.__dict__ for b in result.data if b.customer_id == user.id]
    else:
        bills = []

    return JSONResponse(
        content=bills,
        status_code=status.HTTP_200_OK
    )


