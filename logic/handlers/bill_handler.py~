        # Fetch all data
        all_bills = bill_model.list_bills(db)
        all_payments = payment_history_model.list_payments(db)

        # Global aggregates
        total_billers = len(set(b.biller_id for b in all_bills.data))
        total_customers = len(set(b.customer_id for b in all_bills.data))
        total_bills_systemwide = len(all_bills.data)
        total_amount_billed = sum(b.amount for b in all_bills.data)
        total_paid_amount = sum(p.amount for p in all_payments.data)
        total_outstanding_amount = total_amount_billed - total_paid_amount

        # Monthly aggregation
        monthly_data = defaultdict(lambda: MonthlyReportDto(month="", bills_created=0, amount_billed=0, amount_paid=0))
        for bill in all_bills.data:
            key = get_month_key(bill.created_at)
            dto = monthly_data[key]
            dto.month = key
            dto.bills_created += 1
            dto.amount_billed += bill.amount

        for payment in all_payments.data:
            key = get_month_key(payment.paid_on)
            monthly_data[key].amount_paid += payment.amount

        monthly_report = list(monthly_data.values())

        # Top billers (by amount billed)
        top_billers_map = defaultdict(lambda: {"bills_issued": 0, "amount_billed": 0, "paid": 0})
        for bill in all_bills.data:
            top_billers_map[bill.biller_id]["bills_issued"] += 1
            top_billers_map[bill.biller_id]["amount_billed"] += bill.amount
            if bill.status == "paid":
                top_billers_map[bill.biller_id]["paid"] += bill.amount

        top_billers = [
            AdminTopBillerDto(
                biller_id=biller_id,
                biller_name="BillerName",  # Replace with actual lookup
                bills_issued=data["bills_issued"],
                amount_billed=data["amount_billed"],
                paid_ratio=round(data["paid"] / data["amount_billed"], 2) if data["amount_billed"] else 0.0,
            )
            for biller_id, data in top_billers_map.items()
        ]
        top_billers = sorted(top_billers, key=lambda b: b.amount_billed, reverse=True)[:5]

        # Top debtors (by outstanding amount)
        debtors_map = defaultdict(lambda: {"outstanding": 0, "overdue": 0})
        for bill in all_bills.data:
            if bill.status != "paid":
                debtors_map[bill.customer_id]["outstanding"] += bill.amount
                if bill.status == "overdue":
                    debtors_map[bill.customer_id]["overdue"] += 1

        top_debtors = [
            AdminTopDebtorDto(
                customer_id=cust_id,
                customer_name="CustomerName",  # Replace with actual lookup
                outstanding_amount=data["outstanding"],
                overdue_bills=data["overdue"],
            )
            for cust_id, data in debtors_map.items()
        ]
        top_debtors = sorted(top_debtors, key=lambda d: d.outstanding_amount, reverse=True)[:5]

        return JSONResponse(
            AdminReportDto(
                total_billers=total_billers,
                total_customers=total_customers,
                total_bills_systemwide=total_bills_systemwide,
                total_amount_billed=total_amount_billed,
                total_paid_amount=total_paid_amount,
                total_outstanding_amount=total_outstanding_amount,
                monthly_report=monthly_report,
                top_billers=top_billers,
                top_debtors=top_debtors,
            ).__dict__,
            status_code=status.HTTP_200_OK,
        )

    elif user.role == "biller":
        biller_id = uuid.UUID(user.id)
        bills = bill_model.get_bills_by_biller_id(db,biller_id).data

        payments = payment_history_model.read_payments_by_biller_id(db,biller_id).data

        customer_map = defaultdict(lambda: {
            "name": "CustomerName",  # Replace with lookup
            "total_bills": 0,
            "paid": 0,
            "pending": 0,
            "overdue": 0,
            "total_billed": 0.0,
            "total_paid": 0.0
        })

        for bill in bills:
            c = customer_map[bill.customer_id]
            c["total_bills"] += 1
            c["total_billed"] += bill.amount
            if bill.status == "paid":
                c["paid"] += 1
            elif bill.status == "pending":
                c["pending"] += 1
            elif bill.status == "overdue":
                c["overdue"] += 1

        for payment in payments:
            customer_map[payment.customer_id]["total_paid"] += payment.amount

