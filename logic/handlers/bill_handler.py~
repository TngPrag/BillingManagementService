# CREATE bill (for biller only)
async def write_bill_handler(request: Request, user, background_tasks: BackgroundTasks):
    if user.role != "biller":
        return JSONResponse(
            {"detail": "Not authorized to create bills"},
            status_code=status.HTTP_403_FORBIDDEN,
        )

    try:
        body = await request.json()  # <--- await here
        dto = bill_dto.CreateBillDto(**body)
    except Exception:
        return JSONResponse(
            {"detail": "Invalid bill data"},
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
        )

    # Get a DB session (assuming a sync generator)
    db = next(get_db())  # or however you get your DB session

    new_bill = {
        "customer_id": dto.customer_id,
        "biller_id": user.id,
        "amount": dto.amount,
        "due_date": dto.due_date,
        "status": dto.status,
        "description": dto.description,
        "created_at": datetime.utcnow(),
        "updated_at": datetime.utcnow(),
    }

    # This is a sync function; don't await
    result = bill_model.create_bill(db, new_bill)

    if not result.success:
        return JSONResponse(
            content={"detail": result.error},
            status_code=status.HTTP_400_BAD_REQUEST,
        )

    # Schedule bill reminders using background tasks
    customer = user_model.get_user_by_id(db, dto.customer_id)  # Assuming sync call here too
    # If user_model.get_user_by_id is async, then you must await and adjust DB session accordingly
    if customer:
        background_tasks.add_task(
            schedule_bill_reminders,
            due_date=dto.due_date,
            customer_email=customer.email,
            bill_description=dto.description,
            from_email=os.getenv("SMTP_USER"),
            from_password=os.getenv("SMTP_PASS"),
        )

    return JSONResponse(
        content=result.data.__dict__,
        status_code=status.HTTP_201_CREATED,
    )
# read bill by bill_id : privileged to biller
async def read_bill_handler(request: Request, bill_id: str, user):
    if user.role != "biller":
        return JSONResponse(
            content={"detail": "Not authorized"},
            status_code=status.HTTP_403_FORBIDDEN,
        )

    db = next(get_db())
    bill_id = uuid.UUID(bill_id)
    result = bill_model.get_bill_by_id(db, bill_id)
    if not result.success:
        return JSONResponse(
            content={"detail": result.error},
            status_code=status.HTTP_404_NOT_FOUND,
        )

    return JSONResponse(
        content=result.data.__dict__,
        status_code=status.HTTP_200_OK
    )


