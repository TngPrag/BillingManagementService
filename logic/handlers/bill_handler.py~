            BillerCustomerBillSummaryDto(
                customer_id=cust_id,
                customer_name=data["name"],
                total_bills=data["total_bills"],
                paid=data["paid"],
                pending=data["pending"],
                overdue=data["overdue"],
                total_billed=data["total_billed"],
                total_paid=data["total_paid"],
            )
            for cust_id, data in customer_map.items()
        ]

        monthly_agg = defaultdict(lambda: MonthlyReportDto(month="", bills_created=0, amount_billed=0, amount_paid=0))
        for bill in bills:
            key = get_month_key(bill.created_at)
            dto = monthly_agg[key]
            dto.month = key
            dto.bills_created += 1
            dto.amount_billed += bill.amount

        for payment in payments:
            key = get_month_key(payment.paid_on)
            monthly_agg[key].amount_paid += payment.amount

        return JSONResponse(
            BillerReportDto(
                total_bills_issued=len(bills),
                total_amount_billed=sum(b.amount for b in bills),
                total_paid_amount=sum(p.amount for p in payments),
                total_outstanding_amount=sum(b.amount for b in bills if b.status != "paid"),
                paid_bills_count=len([b for b in bills if b.status == "paid"]),
                pending_bills_count=len([b for b in bills if b.status == "pending"]),
                overdue_bills_count=len([b for b in bills if b.status == "overdue"]),
                bills_per_customer=bills_per_customer,
                monthly_aggregation=list(monthly_agg.values()),
            ).dict(),
            status_code=status.HTTP_200_OK,
        )

    elif user.role == "customer":
        cust_id = uuid.UUID(user.id)

        bills = bill_model.get_bills_by_customer_id(db,cust_id).data
        payments = payment_history_model.read_payments_by_customer_id(db,cust_id).data

        bills_by_biller_map = defaultdict(lambda: {"name": "BillerName", "total_billed": 0.0, "total_paid": 0.0})

        for bill in bills:
            b = bills_by_biller_map[bill.biller_id]
            b["total_billed"] += bill.amount
            if bill.status == "paid":
                b["total_paid"] += bill.amount

        bills_by_biller = [
            CustomerBillByBillerDto(
                biller_id=biller_id,
                biller_name=data["name"],
                total_billed=data["total_billed"],
                total_paid=data["total_paid"],
                outstanding=data["total_billed"] - data["total_paid"],
            )
            for biller_id, data in bills_by_biller_map.items()
        ]

        payment_history = [
            PaymentHistoryDto(
                bill_id=payment.bill_id,
                amount=payment.amount,
                paid_on=payment.paid_on,
                status="paid"  # You can update this if needed
            )
            for payment in payments
        ]

        return JSONResponse(
            CustomerReportDto(
                total_bills_received=len(bills),
                total_amount_due=sum(b.amount for b in bills),
                total_paid=sum(p.amount for p in payments),
                outstanding_amount=sum(b.amount for b in bills if b.status != "paid"),
                paid_bills=len([b for b in bills if b.status == "paid"]),
                pending_bills=len([b for b in bills if b.status == "pending"]),
                overdue_bills=len([b for b in bills if b.status == "overdue"]),
                bills_by_biller=bills_by_biller,
                payment_history=payment_history,
            ).dict(),
            status_code=status.HTTP_200_OK,
        )

    return JSONResponse({"detail": "Unauthorized"}, status_code=status.HTTP_403_FORBIDDEN)

